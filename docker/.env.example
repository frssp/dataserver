# Copy this file to docker/.env (gitignored) and fill in your deployment values.
# `docker compose` auto-loads docker/.env when run from the docker/ directory.

# URL clients use to reach this server. The Zotero 7+ client opens this URL in
# a browser during sign-in, so it MUST be reachable from client machines
# (i.e. NOT 'localhost' unless every client runs on this same host).
# Example: http://192.168.1.10:8080/ or https://zotero.internal.corp/
ZOTERO_BASE_URL=http://localhost:8080/

# Super-user (HTTP Basic) credentials, used by admin.php and internal endpoints.
# Change in production.
ZOTERO_API_SUPER_USERNAME=admin
ZOTERO_API_SUPER_PASSWORD=admin

# Random secret for password hashing. Generate with: openssl rand -hex 32
# DO NOT rotate after first use — all stored password hashes would break.
ZOTERO_AUTH_SALT=zotero_self_hosted_salt

# MySQL root password (used only by `docker compose exec mysql -uroot`).
# The dataserver itself connects as the `zotero` app user from
# docker/init-db/00-create-databases.sql.
MYSQL_ROOT_PASSWORD=zotero_root_pw

# Password for the `zotero` MySQL app user. Must match the password set in
# docker/init-db/00-create-databases.sql (applied on first boot only).
# If you change this on an existing deployment, also run:
#   ALTER USER 'zotero'@'%' IDENTIFIED BY '<new password>';
# and delete include/config/dbconnect.inc.php so it regenerates.
ZOTERO_DB_PASSWORD=zotero_app_pw
